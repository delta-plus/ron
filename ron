def mkagent(platform, ip, port, id):
  count = 1
  file = id + '.nim'
  original = file
  while os.path.isfile('resources/agents/' + file):
    count += 1
    file = id + str(count) + '.nim'
  if file != original:
    original = id
    id = re.sub('\.nim$', '', file)
    add_output('Agent renamed: ' + original + ' -> ' + id + '\n', True)
  with open('resources/agents/agent.nim') as f:
    code = f.read()
  code = re.sub('ADDRESS', ip, code)
  code = re.sub('PORT', port, code)
  code = re.sub('AGENT', id, code)
  with open('resources/agents/' + file, 'w') as f:
    f.write(code)
  while not os.path.isfile('resources/agents/' + file):
    pass
  add_output('Compiling agent...')
  subprocess.run(['resources/builder/build', platform, id],
                 stdout=subprocess.DEVNULL,
                 stderr=subprocess.DEVNULL)
  add_output('Done')
  with open('resources/config.json') as f:
    conf = json.load(f)
  uri = ip + ':' + port
  conf["uris"].append(uri)
  with open('resources/config.json', 'w') as f:
    json.dump(conf, f)
  new_thread = threading.Thread(target=start_websocket_server_in_thread, args=(uri,))
  new_thread.daemon = True
  new_thread.start()

def get_port():
  with socket.socket() as s:
    s.bind(("127.0.0.1", 0))
    return s.getsockname()[1]

def mkbox(val, bold=False, header=False):
  vlen = len(val)
  cols = vlen + 2

  if bold:
    h = '━'
    v = '┃'
    lt = '┣'
    rt = '┫'
    ut = '┳'
    dt = '┻'
    ct = '╋'
    c1 = '┏'
    c2 = '┓'
    c3 = '┗'
    c4 = '┛'
  else:
    h = '─'
    v = '│'
    lt = '├'
    rt = '┤'
    ut = '┬'
    dt = '┴'
    ct = '┼'
    c1 = '┌'
    c2 = '┐'
    c3 = '└'
    c4 = '┘'

  sect = h * cols
 
  if header:
    top = f"{c1}{sect}{c2}"
    mid = f"\n{v} {val} {v}"
    bot = f"\n{c3}{sect}{dt}"
  else:
    top = f"{c1}{sect}{c2}"
    mid = f"\n{v} {val} {v}"
    bot = f"\n{c3}{sect}{c4}"

  return f"{top}{mid}{bot}"

def scroll_lines(listbox, n):
  walker = listbox.body
  if not walker:
    return
  pos = walker.focus if hasattr(walker, "focus") else 0
  new_pos = max(0, min(len(walker) - 1, pos + n))
  walker.set_focus(new_pos)

