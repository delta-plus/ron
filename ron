async def ws(websocket, path):
  try:
    receive = True
    while True:
      global clients
      global new_task
      global shell
      global active_count

      if receive:
        try:
          callback = await websocket.recv()
          if callback.startswith('Hello from '):
            id = callback.split(' ')[2]
            add_output('Callback: ' + id + '\n', True)
            client = add_client(id, websocket.local_address[1])
            clients.append(client)
            receive = False
        except:
          pass
      else:
        for client in clients:
          if client["port"] == websocket.local_address[1] and client["active"] and new_task:
            task = json.dumps(new_task)
            await websocket.send(task)
            response = await websocket.recv()
            if active_count > 1:
              add_output('[' + client["id"] + ']', True)
            add_output(response)
            if shell == 0:
              add_output('')
  
            if response == 'Done':
              client["active"] = False
              active_count -= 1
              clients.remove(client)
              interactive = False
              receive = True

            new_task = None
  except websockets.ConnectionClosed:
    add_output(f"Connection to {path} closed unexpectedly\n")

async def start_websocket_server(uri):
  global websocket_servers
  server = await websockets.serve(ws, uri.split(':')[0], int(uri.split(':')[1]), ssl=ssl_context)
  await server.wait_closed()
  add_output(f"WebSocket server started at {uri}\n")

async def stop_websocket_server(uri):
  global websocket_servers
  if uri in websocket_servers:
    websocket_servers[uri].close()
    await websocket_servers[uri].wait_closed()
    del websocket_servers[uri]
    add_output(f"WebSocket server at {uri} stopped\n")
  else:
    add_output(f"No WebSocket server found for {uri}\n")

def start_websocket_server_in_thread(uri):
  loop = asyncio.new_event_loop()
  asyncio.set_event_loop(loop)
  loop.run_until_complete(start_websocket_server(uri))

def serve():
  with open('resources/config.json') as f:
    uris = json.load(f)["uris"]

  for uri in uris:
    new_thread = threading.Thread(target=start_websocket_server_in_thread, args=(uri,))
    new_thread.daemon = True
    new_thread.start()

new_thread = threading.Thread(target=serve)
