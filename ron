def add_output(string, bold=False):
  if bold:
    widget = urwid.Text([('bold', string)])
  else:
    widget = urwid.Text(string)
  term.walker.append(widget)
  MAX_LINES = rows - 6
  while len(term.walker) > MAX_LINES:
    term.walker.pop(0)
  term.walker.set_focus(len(term.walker) - 1)
  loop.draw_screen()

