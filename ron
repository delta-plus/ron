    self.screen_text = urwid.Text([''])
    self.prompt_text = urwid.Edit('─' * cols + '\n>> ', '')
    self.walker = urwid.SimpleFocusListWalker([self.screen_text])
    self._w = urwid.Frame(header=urwid.Pile([urwid.Text(mkbox(name, False, True) + '─' * (cols - len(name) - 4))]),
                          body=urwid.ListBox(self.walker),
                          footer=self.prompt_text,
                          focus_part='footer')
    self.count = 0
    self.char_limit = 10000
    self.up_count = 0
    self.log_history = deque([], 100)
    self.prompt_history = deque([], 100)

